# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medikl
DB_USER=postgres
DB_PASS=postgres

# Auth
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING_IN_PRODUCTION
JWT_EXPIRATION=7d

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_TEMPERATURE=0.3

# Set to true ONLY in development to allow running the seed script
ALLOW_SEED=false
